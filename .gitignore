# =====================================================
# DuoFeynman — .gitignore
# Nunca subas a Git: secretos, deps, modelos, binarios.
# =====================================================

# --- Secretos y config local ---
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# Virtual envs
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
backend/venv/
backend/.venv/

# Testing & coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# Jupyter
.ipynb_checkpoints

# --- Modelos pesados (descargá de los links del README) ---
# Vosk model (~40-128MB según versión)
backend/models/vosk-en-small/
backend/models/vosk-*/
# Piper TTS (binario + modelo .onnx)
backend/piper/
backend/models/piper/
# Cualquier archivo de modelo grande
*.onnx
*.bin
*.pt
*.pth

# --- Audio / archivos generados ---
*.wav
*.mp3
*.webm
*.ogg
test.wav
test.mp3

# --- Bases de datos locales ---
*.sqlite
*.sqlite3
*.db

# --- Logs ---
*.log
logs/
backend/logs/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- Node (por si en el futuro hay frontend con npm) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Alembic SQL temporales ---
backend/alembic/versions/__pycache__/

# --- Backups y archivos temporales ---
*.bak
*.tmp
*_backup/
_backup/
*.old
