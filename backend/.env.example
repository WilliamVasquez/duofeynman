# DuoFeynman - Variables de entorno
# Copiá este archivo como .env y completá los valores

# === Base de datos MySQL ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=duofeynman_user        # ⚠️ Usar un usuario dedicado, NO root
DB_PASSWORD=                   # ⚠️ Generá una contraseña fuerte aleatoria
DB_NAME=duofeynman

# === Seguridad ===
# 🔑 CRÍTICO: generá uno random con:
#    python -c "import secrets; print(secrets.token_urlsafe(48))"
# Si APP_ENV=production y este es inseguro, la app no arranca.
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# === LanguageTool (gratis, sin key) ===
LANGUAGETOOL_URL=https://api.languagetool.org/v2

# === Vosk (STT offline) ===
VOSK_MODEL_PATH=models/vosk-en-small

# === Piper TTS (opcional fallback offline) ===
PIPER_BINARY_PATH=piper/piper.exe
PIPER_MODEL_PATH=models/piper/en_US-amy-medium.onnx

# === Voz TTS por defecto ===
DEFAULT_VOICE=aria

# === App ===
# APP_ENV: development | production
# En production:
#   - SECRET_KEY no puede ser default ni < 32 caracteres
#   - CORS_ORIGINS no puede contener '*'
#   - DB_PASSWORD no puede ser default ni vacío
#   - Se ocultan /docs y /redoc
#   - Se aplican headers HSTS y CSP estricto
#   - Errores 500 no muestran stack trace
APP_ENV=development

# ⚠️ En PRODUCCIÓN: solo los dominios reales, sin '*'
# Ejemplo prod: CORS_ORIGINS=https://duofeynman.tudominio.com
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
